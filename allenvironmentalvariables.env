# =========================================================
# MediLink - All Environment Variables (Single Copy File)
# =========================================================
# Use this file as a single source, then copy key/value pairs
# into Render Environment Variables.

# -------------------------
# Backend (Render Web Service)
# -------------------------
NODE_ENV=production
PORT=10000
FRONTEND_URL=https://YOUR-FRONTEND-ON-RENDER.onrender.com

JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_POOL_SIZE=20
ADMIN_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
TARGET_DB=medilink

# Must be exactly 64 hex characters
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
ALLOW_JSON_EMAIL_FALLBACK=false

# SMS (optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000

# AI / Chatbot (optional)
PINECONE_API_KEY=your-pinecone-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
CHATBOT_DEBUG_RETRIEVAL=false

# -------------------------
# Frontend (Render Static Site)
# -------------------------
VITE_API_BASE_URL=https://YOUR-BACKEND-ON-RENDER.onrender.com/api
VITE_CHATBOT_API_URL=https://YOUR-CHATBOT-ON-RENDER.onrender.com/api/chat
VITE_DEEPSEEK_API_KEY=your-deepseek-api-key
VITE_OPENROUTER_API_KEY=your-openrouter-api-key

