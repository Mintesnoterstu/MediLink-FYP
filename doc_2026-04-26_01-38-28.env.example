# Backend / Chatbot (Flask: backend/chatbot)
PINECONE_API_KEY=your-pinecone-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# Optional: default https://api.deepseek.com/v1
# DEEPSEEK_API_URL=https://api.deepseek.com/v1
# Optional: default deepseek-chat
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# Same value as DEEPSEEK_API_KEY — needed for Vite (root .env, see frontend/vite.config envDir)
VITE_DEEPSEEK_API_KEY=your-deepseek-api-key-here
# VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Optional: override chatbot API URL (frontend → Flask RAG chat)
# VITE_CHATBOT_API_URL=http://localhost:5001/api/chat

# Existing frontend API base (if you add a REST backend later)
# VITE_API_BASE_URL=http://localhost:3001/api

# Optional: OpenRouter instead of direct DeepSeek in deepSeekService (in-browser AI helpers)
# VITE_OPENROUTER_API_KEY=

# PostgreSQL / MediLink DB (see database/README.md)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medilink
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# JWT_SECRET=change-me-in-production
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# SMTP / Email (Gmail example; use App Password, never your account password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# MAIL_FROM=your-email@gmail.com
# ALLOW_JSON_EMAIL_FALLBACK=false

# Chatbot: include English retrieval query in JSON (debug)
# CHATBOT_DEBUG_RETRIEVAL=true

